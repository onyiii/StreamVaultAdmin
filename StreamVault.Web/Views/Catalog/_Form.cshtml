
@using StreamVault.Web.Models
@using StreamVault.Web.ViewModels
@model BasePropertiesForm
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<input asp-for="Id" type="hidden" />
<div class="row g-3">
    <div class="col-md-6"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control" /><span asp-validation-for="Title" class="text-danger"></span></div>
    <div class="col-md-6">
        <label asp-for="Type" class="form-label"></label>
        @if (Model.Id is null)
        {
            <select asp-for="Type" asp-items="Html.GetEnumSelectList<ContentType>()" class="form-select" data-content-type></select>
        }
        else
        {

            <input type="hidden" asp-for="Type" /><input class="form-control" value="@Model.Type.ToString().Replace("MusicAlbum", "Music album")" disabled />
        }
    </div>
    <div class="col-12"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="3"></textarea><span asp-validation-for="Description" class="text-danger"></span></div>
    <div class="col-md-4"><label asp-for="ReleaseDate" class="form-label"></label><input asp-for="ReleaseDate" class="form-control" /><span asp-validation-for="ReleaseDate" class="text-danger"></span></div>
    <div class="col-md-4"><label asp-for="AgeRating" class="form-label"></label><select asp-for="AgeRating" asp-items="Html.GetEnumSelectList<AgeRating>()" class="form-select"></select></div>
    <div class="col-md-4"><label asp-for="Genre" class="form-label"></label><input asp-for="Genre" class="form-control" /><span asp-validation-for="Genre" class="text-danger"></span></div>
</div>
<hr class="my-4" />
<h2 class="h5 mb-3">Type-specific details</h2>
<div class="row g-3 type-fields" data-types="Movie,Audiobook"><div class="col-md-6"><label asp-for="DurationMinutes" class="form-label"></label><input asp-for="DurationMinutes" class="form-control" min="1" /><span asp-validation-for="DurationMinutes" class="text-danger"></span></div></div>
<div class="row g-3 type-fields" data-types="Movie"><div class="col-md-6"><label asp-for="Director" class="form-label"></label><input asp-for="Director" class="form-control" /><span asp-validation-for="Director" class="text-danger"></span></div></div>
<div class="row g-3 type-fields" data-types="Series">
    <div class="col-md-6"><label asp-for="NumberOfSeasons" class="form-label"></label><input asp-for="NumberOfSeasons" class="form-control" min="1" /><span asp-validation-for="NumberOfSeasons" class="text-danger"></span></div>
    <div class="col-md-6"><label asp-for="TotalEpisodes" class="form-label"></label><input asp-for="TotalEpisodes" class="form-control" min="1" /><span asp-validation-for="TotalEpisodes" class="text-danger"></span></div>
</div>
<div class="row g-3 type-fields" data-types="Audiobook">
    <div class="col-md-6"><label asp-for="Author" class="form-label"></label><input asp-for="Author" class="form-control" /><span asp-validation-for="Author" class="text-danger"></span></div>
    <div class="col-md-6"><label asp-for="Narrator" class="form-label"></label><input asp-for="Narrator" class="form-control" /><span asp-validation-for="Narrator" class="text-danger"></span></div>
</div>
<div class="row g-3 type-fields" data-types="MusicAlbum">
    <div class="col-md-4"><label asp-for="Artist" class="form-label"></label><input asp-for="Artist" class="form-control" /><span asp-validation-for="Artist" class="text-danger"></span></div>
    <div class="col-md-4"><label asp-for="TrackCount" class="form-label"></label><input asp-for="TrackCount" class="form-control" min="1" /><span asp-validation-for="TrackCount" class="text-danger"></span></div>
    <div class="col-md-4"><label asp-for="RecordLabel" class="form-label"></label><input asp-for="RecordLabel" class="form-control" /><span asp-validation-for="RecordLabel" class="text-danger"></span></div>
</div>
<div class="mt-4 d-flex gap-2"><button class="btn btn-primary">Save content</button><a asp-action="Index" class="btn btn-outline-secondary">Cancel</a></div>
