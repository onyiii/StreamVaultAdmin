@using StreamVault.Web.Models 
@using StreamVault.Web.ViewModels
@model CatalogIndexViewModel
@{
    ViewData["Title"] = "Catalogue";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h4 class="mb-1">Content Catalogue</h4><p class="text-secondary mb-0">Manage everything available on StreamVault.</p></div>
    <a asp-action="Create" class="btn btn-primary">Add content</a>
</div>
@if (TempData["Success"] is string message)
{
    <div class="alert alert-success">@message</div>
}
<form method="get" id="catalog-filters" class="row g-2 align-items-end mb-4">
    <div class="col-md-6"><label asp-for="Search" class="form-label">Search by title</label><input asp-for="Search" class="form-control" placeholder="Enter a title" /></div>
    <div class="col-md-3"><label asp-for="Type" class="form-label">Content type</label><select asp-for="Type" asp-items="Html.GetEnumSelectList<ContentType>()" class="form-select" onchange="this.form.requestSubmit()"><option value="">All types</option></select></div>
    <div class="col-md-3 d-flex gap-2"><button class="btn btn-dark flex-grow-1">Filter</button><a asp-action="Index" class="btn btn-outline-secondary">Clear</a></div>
</form>
@if (Model.Items.Count == 0)
{
    <div class="empty-state text-center border rounded-3 p-5"><h2 class="h5">No content found</h2><p class="text-secondary mb-0">Try another filter or add a new catalogue item.</p></div>
}
else
{
    <div class="table-responsive border rounded-3">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light"><tr><th>Title</th><th>Type</th><th>Genre</th><th>Release</th><th>Details</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td><strong>@item.Title</strong><div class="small text-secondary text-truncate description">@item.Description</div></td>
                        <td><span class="badge text-bg-secondary">@item.Type.ToString().Replace("MusicAlbum", "Music album")</span></td>
                        <td>@item.Genre</td>
                        <td>@item.ReleaseDate.ToString("dd MMM yyyy")</td>
                        <td class="small">@item.Details</td>
                        <td class="text-end text-nowrap"><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a> <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

